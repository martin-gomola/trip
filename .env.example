# TRIP Configuration
# Self-hosted POI map tracker & trip planner: https://github.com/itskovacs/trip

# Data path - Linux: leave commented (defaults to /srv/docker)
# macOS: uncomment and set your home path
#DATA_DIR=$HOME/srv/docker

# Container image version (major tag pinned)
TRIP_VERSION=1

# Local image name used by docker compose after building this fork.
TRIP_IMAGE=trip-local

# Host port for TRIP web UI (container exposes 8000 internally)
TRIP_PORT=8050

# Timezone
TZ=UTC

# Public URL/domain. Optional for local-only installs, useful for reverse proxy and integrations.
# TRIP_DOMAIN=trip.yourdomain.com
# TRIP_BASE_URL=https://trip.yourdomain.com

# Registration toggle. Set to "true" to allow new accounts to self-register.
# Recommended: keep "false" after creating your first user.
REGISTER_ENABLE=false

# Default map center. Set to your preferred home/base location.
# DEFAULT_MAP_LAT=
# DEFAULT_MAP_LNG=

# API token for integrations. Keep secret; do not commit your real value.
# TRIP_API_TOKEN=replace-me

# Optional local browser-review login for agent-browser UI checks.
# Keep real values only in private .env; never commit real credentials.
# Set TRIP_ADMIN_USERNAME and TRIP_ADMIN_PASSWORD in your private .env.

# Mapy.com REST API key. Enables Mapy.com map tile presets in Settings.
# The key is read from runtime config and is not stored in user settings.
# Set MAPY_COM_API_KEY in your private .env when needed.
# Example key assignment intentionally omitted; keep the real value only in private runtime config.

# --- Optional: OIDC SSO ---
# Configure these to enable single sign-on via your identity provider.
# When all four are set, TRIP exposes the OIDC login flow.
# OIDC_DISCOVERY_URL=https://sso.yourdomain.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=trip
# OIDC_CLIENT_SECRET=replace-me
# OIDC_REDIRECT_URI=https://trip.yourdomain.com/auth

# --- Optional: tuning ---
# Resize uploaded images. Larger = more disk usage.
# PLACE_IMAGE_SIZE=500
# TRIP_IMAGE_SIZE=600

# Max attachment size in bytes (default 10 MB).
# Remember to bump your reverse proxy's body limit too (NPM/Nginx: client_max_body_size).
# ATTACHMENT_MAX_SIZE=10485760

# Token lifetimes (minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_MINUTES=1440
